# QuickAid Client Environment Variables Example

# API URL
VITE_API_URL=http://localhost:3001

# Map Configuration (using OpenStreetMap - no key required)
VITE_MAP_CENTER_LAT=1.3521
VITE_MAP_CENTER_LNG=103.8198
VITE_MAP_DEFAULT_ZOOM=12

# Google Maps API (optional - remove if using OpenStreetMap)
# Get your key from: https://developers.google.com/maps/documentation/javascript/get-api-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here