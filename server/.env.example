# QuickAid Server Environment Variables Example

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/quickaid

# JWT Secrets (minimum 32 characters each)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-please-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-please-change-this

# Google Gemini AI Configuration
GEMINI_API_KEY=your-google-gemini-api-key

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Security
BCRYPT_ROUNDS=12