# QuickAid Environment Variables

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/quickaid

# JWT Secrets (minimum 32 characters each)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# Google Gemini AI Configuration
GEMINI_API_KEY=AIza-your-gemini-api-key-here

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Security
BCRYPT_ROUNDS=12

# Frontend (Vite)
VITE_API_URL=http://localhost:3001

# Map Configuration (using OpenStreetMap - no key required)
VITE_MAP_CENTER_LAT=1.3521
VITE_MAP_CENTER_LNG=103.8198
VITE_MAP_DEFAULT_ZOOM=12